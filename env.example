# Demo credentials — fine for local learning, never for anything public.
# NOTE: MinIO credentials are also hardcoded in:
#   flink/sql-jobs/clickstream-filtering.sql  (CREATE CATALOG block)
#   trino/iceberg.properties
# If you change them here, change them there too.

MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password

SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_EMAIL=admin@superset.com
SUPERSET_ADMIN_PASSWORD=admin
# Generate your own: openssl rand -base64 42
SUPERSET_SECRET_KEY=change-me-long-random-string

KAFKA_TOPIC=clickstream
